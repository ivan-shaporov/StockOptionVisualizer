# Copy this file to .env and fill in real values.

# === download_option_data.py ===

# Required to download new data
# marketdata.app credentials
MARKETDATA_TOKEN=replace-with-your-marketdata-token
SYMBOL=AAPL
SIDE=put

# Quote history: include QUOTE_LATEST_DATE and walk back QUOTE_DAYS_BACK
# calendar days from there. If QUOTE_LATEST_DATE is omitted or blank, the
# downloader uses today's date. Example below captures 2024-03-01 through
# 2024-03-15 inclusive.
# QUOTE_LATEST_DATE=2024-03-15
QUOTE_DAYS_BACK=14

EXP_FROM=2024-03-15
EXP_TO=2024-03-15

# Optional chain filters (passed to the API)
# STRIKE=170-190
# DELTA=-0.5--0.2
# RANGE=otm
# MIN_VOLUME=10
# MIN_OPEN_INTEREST=50

# Optional chain walk step size in days to find all available symbols. Defaults to 7.
# LOOKBACK_STEP_DAYS=7

# Write one CSV per option contract in addition to the combined file.
# Defaults to off.
# WRITE_CHUNK_FILES=0

# === Shared ===

# Optional output root, used by both scripts. Defaults to ./data
# OUT_DIR=./data

# === plot_option_prices.py ===
# The plotter only needs SYMBOL + SIDE (above) to locate
#   OUT_DIR/SYMBOL/SIDE/all_{SIDE}s.csv
# or you can override the path explicitly:
# PLOT_CSV=./data/AAPL/put/all_puts.csv

# Plot field: bid | mid | ask | last | loss | loss@n%. Defaults to mid.
# loss is put-only and shows protective-put loss % under an 80% market drop.
# loss@n% uses n/100 as the post-crash underlying price, so loss@30%
# means a 70% market drop.
# PLOT_FIELD=mid

# Default slider range when --strike is omitted, as fractions of the latest
# underlying price.
# Defaults to 0.7 and 0.8.
# INITIAL_STRIKE_MIN_PRICE_FRACTION=0.7
# INITIAL_STRIKE_MAX_PRICE_FRACTION=0.8
